const SEL_LABELS = { profile: 'プロフィール', club: '使用クラブ', ball: '使用ボール', weather: '天気情報' };

function openSelectModal(type) {
    selectModalType = type;
    document.getElementById('select-modal-title').textContent = SEL_LABELS[type] + ' を選択';
    renderSelectList(type);
    document.getElementById('select-modal').classList.add('active');
}

function closeSelectModal(e) {
    if (e && e.target !== document.getElementById('select-modal')) return;
    document.getElementById('select-modal').classList.remove('active');
    selectModalType = null;
}

function renderSelectList(type) {
    const presets = S.presets(type);
    const defId = S.defId(type);
    const cur = selected[type];
    const el = document.getElementById('select-modal-list');

    if (!presets.length) { 
        el.innerHTML = '<p style="text-align:center;color:var(--text-muted);padding:24px 0;">プリセットがありません</p>'; 
        return; 
    }
    
    el.innerHTML = presets.map(p => {
        const subtitle = type === 'club' && p.clubType ? `<div class="preset-subtitle">種類: ${p.clubType}</div>` : '';
        return `
            <div class="preset-item ${cur && cur.id === p.id ? 'selected' : ''}" onclick="selectPreset('${type}', ${p.id})">
                <div style="flex:1">
                    <div class="preset-name">${p.name}</div>
                    ${subtitle}
                </div>
                ${cur && cur.id === p.id ? '<span class="active-badge">使用中</span>' : ''}
                ${p.id === defId ? '<span class="default-badge">デフォルト</span>' : ''}
            </div>
        `;
    }).join('');
}

function selectPreset(type, id) {
    const preset = S.presets(type).find(p => p.id === id);
    if (!preset) return;
    selected[type] = preset;
    updateMainRow(type, preset.name, preset.clubType);
    closeSelectModal();
}

function updateMainRow(type, name, clubType) {
    const el = document.getElementById('main-' + type);
    if (!el) return;
    
    if (name) { 
        el.textContent = name; 
    } else { 
        el.textContent = ''; 
    }

    if (type === 'club') {
        const typeBox = document.getElementById('main-club-type');
        typeBox.textContent = clubType ? (CLUB_TYPE_MAP[clubType] || "---") : "---";
    }
}

// ==================== Settings: Management ====================
function renderAllMgmtLists() { TYPES.forEach(type => renderMgmtList(type)); }

function renderMgmtList(type) {
    const el = document.getElementById('mgmt-list-' + type);
    if (!el) return;
    const presets = S.presets(type);
    const defId = S.defId(type);
    
    if (!presets.length) { el.innerHTML = '<p style="font-size:13px;color:var(--text-muted);text-align:center;padding:10px 0;">なし</p>'; return; }
    
    el.innerHTML = presets.map(p => {
        const subtitle = type === 'club' && p.clubType ? `<div class="preset-subtitle">(${p.clubType})</div>` : '';
        return `
            <div class="preset-mgmt-item ${p.id === defId ? 'is-default' : ''}">
                <div style="flex:1">
                    <div class="preset-name">${p.name} ${p.id === defId ? '<span class="default-badge" style="margin-left:6px;">デフォルト</span>' : ''}</div>
                    ${subtitle}
                </div>
                <button class="btn btn-secondary btn-sm" onclick="setDefault('${type}',${p.id})" title="デフォルトに設定">⭐</button>
                <button class="btn btn-secondary btn-sm" onclick="openEditModal('${type}',${p.id})">✏️</button>
                <button class="btn btn-danger btn-sm" onclick="deletePreset('${type}',${p.id})">🗑</button>
            </div>
        `;
    }).join('');
}

function setDefault(type, id) {
    S.setDef(type, id); renderMgmtList(type);
    if (!selected[type]) {
        const p = S.presets(type).find(x => x.id === id);
        if (p) { selected[type] = p; updateMainRow(type, p.name, p.clubType); }
    }
}

function deletePreset(type, id) {
    if (!confirm('削除しますか？')) return;
    S.savePresets(type, S.presets(type).filter(p => p.id !== id));
    if (S.defId(type) === id) S.setDef(type, null);
    if (selected[type]?.id === id) { selected[type] = null; updateMainRow(type, null, null); }
    renderMgmtList(type);
}

