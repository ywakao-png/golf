    document.getElementById('edit-modal-title').textContent = SEL_LABELS[type] + ' を追加';
    document.getElementById('edit-modal-form').innerHTML = buildEditForm(type, null);
    document.getElementById('edit-modal').classList.add('active');
}

function openEditModal(type, id) {
    editModalType = type; editModalId = id;
    const preset = S.presets(type).find(p => p.id === id);
    if (!preset) return;
    editGender = preset.gender || '男性';
    document.getElementById('edit-modal-title').textContent = SEL_LABELS[type] + ' を編集';
    document.getElementById('edit-modal-form').innerHTML = buildEditForm(type, preset);
    document.getElementById('edit-modal').classList.add('active');
}

function closeEditModal(e) {
    if (e && e.target !== document.getElementById('edit-modal')) return;
    document.getElementById('edit-modal').classList.remove('active');
}

function buildEditForm(type, preset) {
    const v = (field, def = '') => preset ? (preset[field] ?? def) : def;
    
    if (type === 'profile') {
        return `
            <label>名前</label><input type="text" id="ef-name" value="${v('name')}">
            <label>性別</label>
            <div class="toggle-group">
                <button class="toggle-opt ${editGender === '男性' ? 'active' : ''}" onclick="setEditGender('男性',this)">男性</button>
                <button class="toggle-opt ${editGender === '女性' ? 'active' : ''}" onclick="setEditGender('女性',this)">女性</button>
            </div>
            <div class="grid-2">
                <div><label>年齢</label><div class="input-unit"><input type="number" id="ef-age" value="${v('age')}"><span class="unit">歳</span></div></div>
                <div><label>身長</label><div class="input-unit"><input type="number" id="ef-height" value="${v('height')}"><span class="unit">cm</span></div></div>
            </div>
            <label>体重</label><div class="input-unit" style="max-width:160px;"><input type="number" id="ef-weight" value="${v('weight')}"><span class="unit">kg</span></div>
        `;
    }
    if (type === 'club') {
        return `
            <label>クラブ名</label><input type="text" id="ef-name" value="${v('name')}" placeholder="例：TaylorMade Stealth 2">
            <label>クラブの種類</label>
            <select id="ef-club-type">
                <option value="ドライバー" ${v('clubType') === 'ドライバー' ? 'selected' : ''}>ドライバー</option>
                <option value="フェアウェイウッド" ${v('clubType') === 'フェアウェイウッド' ? 'selected' : ''}>フェアウェイウッド</option>
                <option value="ユーティリティ" ${v('clubType') === 'ユーティリティ' ? 'selected' : ''}>ユーティリティ</option>
                <option value="アイアン" ${v('clubType') === 'アイアン' ? 'selected' : ''}>アイアン</option>
                <option value="ウェッジ" ${v('clubType') === 'ウェッジ' ? 'selected' : ''}>ウェッジ</option>
                <option value="パター" ${v('clubType') === 'パター' ? 'selected' : ''}>パター</option>
            </select>
        `;
    }
    if (type === 'ball') {
        return `<label>ボール名</label><input type="text" id="ef-name" value="${v('name')}">`;
    }
    if (type === 'weather') {
        return `
            <label>プリセット名</label><input type="text" id="ef-name" value="${v('name')}">
            <label>地面の硬さ</label><input type="text" id="ef-ground" value="${v('ground')}">
            <div class="grid-2">
                <div><label>温度</label><div class="input-unit"><input type="number" id="ef-temp" value="${v('temp')}"><span class="unit">°C</span></div></div>
                <div><label>湿度</label><div class="input-unit"><input type="number" id="ef-humidity" value="${v('humidity')}"><span class="unit">%</span></div></div>
                <div><label>気圧</label><div class="input-unit"><input type="number" id="ef-pressure" value="${v('pressure')}"><span class="unit">hPa</span></div></div>
                <div><label>風速</label><div class="input-unit"><input type="number" id="ef-windspd" value="${v('windspd')}"><span class="unit">m/s</span></div></div>
            </div>
            <label>風向き</label><div class="input-unit"><input type="number" id="ef-winddir" value="${v('winddir')}"><span class="unit">°</span></div>
        `;
    }
}

function setEditGender(g, btn) {
    editGender = g;
    btn.closest('.toggle-group').querySelectorAll('.toggle-opt').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
}

function confirmEdit() {
    const name = document.getElementById('ef-name')?.value.trim();
    if (!name) { alert('名前を入力してください'); return; }

    const gv = id => document.getElementById(id)?.value || '';
    let data = { name };
    
    if (editModalType === 'profile') {
        data.gender = editGender; data.age = gv('ef-age'); data.height = gv('ef-height'); data.weight = gv('ef-weight');
    } else if (editModalType === 'club') {
        data.clubType = gv('ef-club-type');
    } else if (editModalType === 'weather') {
        data.ground = gv('ef-ground'); data.temp = gv('ef-temp'); data.humidity = gv('ef-humidity'); 
        data.pressure = gv('ef-pressure'); data.windspd = gv('ef-windspd'); data.winddir = gv('ef-winddir');
    }

    const presets = S.presets(editModalType);
    if (editModalId) {
        const idx = presets.findIndex(p => p.id === editModalId);
        if (idx >= 0) presets[idx] = { ...presets[idx], ...data };
        if (selected[editModalType]?.id === editModalId) {
            selected[editModalType] = presets[idx];
            updateMainRow(editModalType, presets[idx].name, presets[idx].clubType);
        }
    } else {
        data.id = Date.now(); presets.push(data);
        if (presets.length === 1) S.setDef(editModalType, data.id);
    }
    S.savePresets(editModalType, presets);
    renderMgmtList(editModalType);
    closeEditModal();
}

// ==================== Export / Import ====================
function exportSettings() {
    const data = {}; TYPES.forEach(t => { data['p_' + t] = S.presets(t); data['d_' + t] = S.defId(t); });
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = 'golf_settings.json'; a.click();
}
function importSettings(event) {
    const file = event.target.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
        try {
            const data = JSON.parse(e.target.result);
            TYPES.forEach(t => { if (data['p_' + t]) S.savePresets(t, data['p_' + t]); if (data['d_' + t]) S.setDef(t, data['d_' + t]); });
            loadDefaults(); renderAllMgmtLists(); alert('インポートしました！');
        } catch { alert('エラーが発生しました。'); }
    };
    reader.readAsText(file);
}

// ==================== API Settings ====================
function saveApiKey() { 
    S.set('apikey', document.getElementById('api-key').value.trim()); 
    S.set('gemini_apikey', document.getElementById('gemini-api-key').value.trim()); 
    alert('APIキーを保存しました'); 
}

function saveModel() { 
    S.set('diag_model', document.getElementById('diag-model').value);
    S.set('adv_model', document.getElementById('adv-model').value);
    alert('モデル設定を保存しました'); 
}

// ==================== Prompt Builders ====================
function formatProfile() {
    const p = selected['profile']; if (!p) return '';
    let t = `[プロフィール]\n性別: ${p.gender}\n`;
    if (p.age) t += `年齢: ${p.age}歳\n`; if (p.height) t += `身長: ${p.height}cm\n`; if (p.weight) t += `体重: ${p.weight}kg\n`;
    return t + '\n';
}

function formatWeather() {
    const w = selected['weather']; if (!w) return '';
    const { ground, temp, humidity, pressure, windspd, winddir } = w;
    if (!(ground || temp || humidity || pressure || windspd || winddir)) return '';
    let t = `[天気環境]\n`;
    if (ground) t += `地面: ${ground}\n`; if (temp) t += `温度: ${temp}°C\n`; if (humidity) t += `湿度: ${humidity}%\n`; 
    if (pressure) t += `気圧: ${pressure}hPa\n`; if (windspd) t += `風速: ${windspd}m/s\n`; if (winddir) t += `風向: ${winddir}°\n`;
    return t + '\n';
}

function buildDiagnosisPrompt() {
    const selClub = selected['club'];
    let p = "";
    if (DIAGNOSIS_SHARED_RULE.trim()) p += `[共有ルール]\n${DIAGNOSIS_SHARED_RULE.trim()}\n\n`;
    if (selClub && selClub.clubType && DIAGNOSIS_CLUB_RULES[selClub.clubType]?.trim()) {
        p += `[クラブルール]\n${DIAGNOSIS_CLUB_RULES[selClub.clubType].trim()}\n\n`;
    }
    p += formatProfile();
    if (selClub) p += `[使用クラブ]\n${selClub.name}\n\n`;
    if (selected['ball']) p += `[使用ボール]\n${selected['ball'].name}\n\n`;
    p += formatWeather();
    p += `[ショットデータ]\n${document.getElementById('golf-data').value.trim()}\n`;
    return p;
}

function buildAdvicePrompt(diagText) {
    const selClub = selected['club'];
    let p = "";
    if (ADVICE_SHARED_RULE.trim()) p += `[共有ルール]\n${ADVICE_SHARED_RULE.trim()}\n\n`;
    if (selClub && selClub.clubType && ADVICE_CLUB_RULES[selClub.clubType]?.trim()) {
        p += `[クラブルール]\n${ADVICE_CLUB_RULES[selClub.clubType].trim()}\n\n`;
    }
    p += formatProfile();
    p += formatWeather();
    p += `[診断結果]\n${diagText}\n`;
    return p;
}

// ==================== API Stream Logic ====================
async function fetchAIStream(prompt, modelType, onChunk, onComplete) {
    const model = S.get(modelType) || (modelType === 'diag_model' ? 'gemini-2.5-flash' : 'gpt-5-mini');
    const isGemini = model.startsWith('gemini');
    const apiKey = isGemini ? S.get('gemini_apikey') : S.get('apikey');
    
    if (!apiKey) throw new Error(`${isGemini ? 'Gemini' : 'OpenAI'}のAPIキーが未設定です。`);

    let url, headers, body;
    if (isGemini) {
        url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:streamGenerateContent?alt=sse&key=${apiKey}`;
        headers = { 'Content-Type': 'application/json' };
        body = JSON.stringify({ contents: [{ role: "user", parts: [{ text: prompt }] }] });
    } else {
        url = 'https://api.openai.com/v1/chat/completions';
        headers = { 'Content-Type': 'application/json', 'Authorization': `Bearer ${apiKey}` };
        body = JSON.stringify({ model, messages: [{ role: 'user', content: prompt }], stream: true });
    }

    const res = await fetch(url, { method: 'POST', headers, body });
    if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.error?.message || `HTTPエラー ${res.status}`);
    }

    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buf = '';
    let fullText = '';

    while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += decoder.decode(value, { stream: true });
        const lines = buf.split('\n'); buf = lines.pop();
        for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            const raw = line.slice(6).trim();
            if (raw === '[DONE]') break;
            if (!raw) continue;
            try {
                const data = JSON.parse(raw);
                const chunk = isGemini ? (data.candidates?.[0]?.content?.parts?.[0]?.text || '') : (data.choices?.[0]?.delta?.content || '');
                fullText += chunk;
                onChunk(chunk);
            } catch {}
        }
    }
    if (onComplete) onComplete(fullText);
}

// ==================== Generate Process ====================
async function generateAdvice() {
    if (!document.getElementById('golf-data').value.trim()) { alert('ショットデータを貼り付けてください。'); return; }

    const resultView = document.getElementById('result-view');
    const loading = document.getElementById('result-loading');
    const loadingText = document.getElementById('loading-status-text');
    const content = document.getElementById('advice-content');
    const btnShowDiag = document.getElementById('btn-show-diagnosis');
    const btnCopy = document.getElementById('btn-copy');

    // 表示リセット
    resultView.style.display = 'block';
    content.textContent = '';
    btnShowDiag.style.display = 'none';
    btnCopy.style.display = 'none';
    
    loading.style.display = 'block';
    loadingText.textContent = 'データを診断中...';
    
    resultView.scrollIntoView({ behavior: 'smooth' });

    currentDiagnosisText = "";
    
    try {
        // STEP 1: 診断のバックグラウンド実行
        const prompt1 = buildDiagnosisPrompt();
        await fetchAIStream(prompt1, 'diag_model', () => {}, (text) => { currentDiagnosisText = text; });
        btnShowDiag.style.display = 'inline-block';

        // STEP 2: アドバイスの実行と表示
        const selClub = selected['club'];
        const hasAdvRule = (ADVICE_SHARED_RULE.trim() !== '') || (selClub && selClub.clubType && ADVICE_CLUB_RULES[selClub.clubType]?.trim() !== '');
        
        if (!hasAdvRule) {
            loading.style.display = 'none';
            content.innerHTML = `<div style="text-align:center; color:var(--text-muted); font-size:12px;">アドバイス用ルールが未設定のため、アドバイスの生成はスキップされました。<br>上のボタンから診断結果を確認できます。</div>`;
            return;
        }

        loadingText.textContent = 'アドバイスを生成中...';

        const prompt2 = buildAdvicePrompt(currentDiagnosisText);
        
        let isFirstChunk = true;
        await fetchAIStream(prompt2, 'adv_model', (chunk) => {
            if (isFirstChunk) {
                loading.style.display = 'none'; // 最初の文字が出た瞬間にローディングを消す
                isFirstChunk = false;
            }
            content.textContent += chunk;
            // 自動スクロール
            const bottom = resultView.getBoundingClientRect().bottom;
            if(bottom > window.innerHeight) window.scrollBy(0, 50);
        }, () => {
            if (isFirstChunk) loading.style.display = 'none'; // 万が一空だった時の保険
            btnCopy.style.display = 'block';
        });

    } catch(err) { 
        loading.style.display = 'none';
        content.innerHTML = `<div class="error-box">❌ エラー: ${err.message}</div>`; 
    }
}

async function copyAdvice(btn) {
    const text = document.getElementById('advice-content')?.textContent; 
    if (!text) return;
    try { 
        await navigator.clipboard.writeText(text); 
        const o = btn.textContent; 
        btn.textContent = '✅ コピー完了'; 
        setTimeout(() => btn.textContent = o, 2000); 
    } catch { alert('コピー失敗'); }
}

function loadDefaults() { 
    TYPES.forEach(t => { 
        const d = S.defId(t); 
        if(d) { 
            const p = S.presets(t).find(x => x.id === d); 
            if(p) { selected[t] = p; updateMainRow(t, p.name, p.clubType); } 
        } 
    }); 
}

function init() {
    loadDefaults();
    if (S.get('apikey')) document.getElementById('api-key').value = S.get('apikey');
    if (S.get('gemini_apikey')) document.getElementById('gemini-api-key').value = S.get('gemini_apikey');
    document.getElementById('diag-model').value = S.get('diag_model') || 'gemini-2.5-flash';
    document.getElementById('adv-model').value = S.get('adv_model') || 'gemini-2.5-flash';
}

init();
</script>
